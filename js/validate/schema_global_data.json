{
    "$id": "https:://strayed.site/schema/schema_global_data.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Global Data Schema",
    "type": "object",
    "required": ["version_info", "global_data"],
    "additionalProperties": false,
    "properties": {
        "version_info": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+-(alpha|beta|(release|rv))-[0-9]+"
        },
        "global_data": {
            "type": "object",
            "required": ["mcsRootDir", "maintenanceMode", "serverScheduleTime"],
            "additionalProperties": false,
            "properties": {
                "mcsRootDir": {
                    "type": "string"
                },
                "maintenanceMode": {
                    "type": "boolean"
                },
                "serverScheduleTime": {
                    "type": "object",
                    "required": ["dayReboot", "weeklyShutdown", "pluginServBuildPull"],
                    "additionalProperties": false,
                    "properties": {
                        "dayReboot": {
                            "type": "object",
                            "required": ["motd", "exec"],
                            "additionalProperties": false,
                            "properties": {
                                "motd": {
                                    "type": "string",
                                    "pattern": "^([0-9]|[1-5][0-9]|\\*) ([0-9]|[1-5][0-9]|\\*) ([0-9]|1[0-9]|2[0-3]|\\*) ([0-9]|[1-2][0-9]|3[0-1]|\\*) ([1-9]|1[0-2]|\\*) ([0-7]|\\*)$"
                                },
                                "exec": {
                                    "type": "string",
                                    "pattern": "^([0-9]|[1-5][0-9]|\\*) ([0-9]|[1-5][0-9]|\\*) ([0-9]|1[0-9]|2[0-3]|\\*) ([0-9]|[1-2][0-9]|3[0-1]|\\*) ([1-9]|1[0-2]|\\*) ([0-7]|\\*)$"
                                }
                            }
                        },
                        "weeklyShutdown": {
                            "type": "object",
                            "required": ["motd", "exec"],
                            "additionalProperties": false,
                            "properties": {
                                "motd": {
                                    "type": "string",
                                    "pattern": "^([0-9]|[1-5][0-9]|\\*) ([0-9]|[1-5][0-9]|\\*) ([0-9]|1[0-9]|2[0-3]|\\*) ([0-9]|[1-2][0-9]|3[0-1]|\\*) ([1-9]|1[0-2]|\\*) ([0-7]|\\*)$"
                                },
                                "exec": {
                                    "type": "string",
                                    "pattern": "^([0-9]|[1-5][0-9]|\\*) ([0-9]|[1-5][0-9]|\\*) ([0-9]|1[0-9]|2[0-3]|\\*) ([0-9]|[1-2][0-9]|3[0-1]|\\*) ([1-9]|1[0-2]|\\*) ([0-7]|\\*)$"
                                }
                            }
                        },
                        "pluginServBuildPull": {
                            "type": "string",
                            "pattern": "^([0-9]|[1-5][0-9]|\\*) ([0-9]|[1-5][0-9]|\\*) ([0-9]|1[0-9]|2[0-3]|\\*) ([0-9]|[1-2][0-9]|3[0-1]|\\*) ([1-9]|1[0-2]|\\*) ([0-7]|\\*)$"
                        }
                    }
                }
            }
        }
    }
}
